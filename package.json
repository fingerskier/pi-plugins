{
  "name": "@fingerskier/pi-plugins-workspace",
  "version": "2026.5.7",
  "description": "Fingerskier Pi plugin package workspace and marketplace catalog",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm -r --sort build",
    "clean": "node scripts/clean.mjs && pnpm -r --sort clean",
    "lint": "pnpm run validate && pnpm run typecheck",
    "test": "pnpm run validate && pnpm -r --sort test",
    "typecheck": "tsc -b",
    "validate": "node scripts/validate-marketplace.mjs"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi.dev",
    "marketplace",
    "plugins",
    "workspace"
  ],
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@types/node": "^24.3.0",
    "typebox": "^1.1.24",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "koffi",
      "protobufjs"
    ]
  },
  "engines": {
    "node": ">=20.6.0",
    "pnpm": ">=10.0.0"
  },
  "license": "MIT"
}
