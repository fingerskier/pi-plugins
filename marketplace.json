{
  "$schema": "./schemas/pi-marketplace.schema.json",
  "name": "fingerskier-pi-plugins",
  "description": "Pi package ports of Fingerskier Claude plugins",
  "owner": {
    "name": "Fingerskier",
    "email": "fingerskier@gmail.com"
  },
  "plugins": [
    {
      "name": "build123d",
      "package": "@fingerskier/pi-build123d",
      "path": "packages/pi-build123d",
      "description": "CAD modeling with build123d — create, inspect, render, and export parametric 3D models using Python.",
      "category": "productivity",
      "status": "ported",
      "keywords": [
        "cad",
        "3d",
        "build123d",
        "mcp",
        "python"
      ],
      "pi": {
        "install": "pi install npm:@fingerskier/pi-build123d",
        "resources": [
          "extension",
          "skill"
        ],
        "toolPrefix": "build123d",
        "localInstall": "pi install ./packages/pi-build123d"
      },
      "upstream": {
        "type": "claude-plugin",
        "path": "../Claude/build123d-claude-plugin",
        "url": "https://github.com/fingerskier/build123d-claude-plugin",
        "version": "2026.3.10"
      }
    },
