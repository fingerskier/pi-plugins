      "status": "ported",
      "keywords": ["cad", "3d", "build123d", "mcp", "python"],
      "pi": {
        "install": "pi install ./plugins/build123d",
        "resources": ["extension", "skill"],
        "toolPrefix": "build123d"
      },
      "upstream": {
        "type": "claude-plugin",
        "path": "../Claude/build123d-claude-plugin",
