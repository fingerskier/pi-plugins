{
  "name": "@fingerskier/pi-dude",
  "version": "2026.5.7",
  "description": "Dude local memory plugin for Pi, bridged from dude-claude-plugin MCP",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "dude",
    "memory",
    "rag",
    "mcp"
  ],
  "pi": {
    "extensions": [
      "./extensions/dude.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "extensions",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/validate-package.mjs .",
    "lint": "pnpm run build",
    "clean": "node ../../scripts/clean-package.mjs ."
  },
  "dependencies": {
    "@fingerskier/pi-shared": "2026.5.7"
  }
}
