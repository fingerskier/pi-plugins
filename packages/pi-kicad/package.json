{
  "name": "@fingerskier/pi-kicad",
  "version": "2026.5.7",
  "description": "KiCad MCP plugin for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "kicad",
    "pcb",
    "eda",
    "mcp"
  ],
  "pi": {
    "extensions": [
      "./extensions/kicad.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@fingerskier/pi-shared": "2026.5.7",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^9.0.0",
    "koffi": "^2.15.2",
    "protobufjs": "^8.0.0",
    "zod": "^3.23.0"
  },
  "files": [
    "dist",
    "docs",
    "extensions",
    "proto",
    "skills",
    "README.md",
    "README.upstream.md"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/validate-package.mjs .",
    "lint": "pnpm run build",
    "clean": "node ../../scripts/clean-package.mjs ."
  }
}
